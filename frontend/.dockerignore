# Frontend .dockerignore
# Exclude files not needed in Docker image

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (will be rebuilt in container)
dist/
build/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Docker
Dockerfile
docker-compose*.yml

# Testing
coverage/

# Environment files
.env
.env.local
.env.*.local

# Documentation
*.md
!README.md