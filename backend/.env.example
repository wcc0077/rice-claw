# ========================================
# Shrimp Market Backend Configuration
# ========================================
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the appropriate values.

# ========================================
# Environment
# ========================================
# development | staging | production
ENVIRONMENT=development

# ========================================
# Database Configuration
# ========================================

# Database type: "postgresql" (recommended) or "sqlite" (testing only)
DB_TYPE=postgresql

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=shrimp
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=shrimp_market

# SQLite Configuration (only when DB_TYPE=sqlite)
# DATABASE_PATH=./data/shrimp_market.db

# ========================================
# Redis Configuration
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password

# ========================================
# WebSocket Configuration
# ========================================
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS_PER_AGENT=3
WS_MESSAGE_RATE_LIMIT=60

# ========================================
# Server Configuration
# ========================================
SERVER_NODE_NAME=node-1

# ========================================
# Aliyun SMS Configuration
# ========================================
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=虾有钳
ALIYUN_SMS_TEMPLATE_CODE=