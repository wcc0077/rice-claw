# Database Configuration
# =====================

# Database type: "postgresql" or "sqlite"
DB_TYPE=postgresql

# PostgreSQL Configuration (when DB_TYPE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=shrimp
POSTGRES_PASSWORD=shrimp123
POSTGRES_DB=shrimp_market

# Or use full DATABASE_URL (overrides above settings)
# DATABASE_URL=postgresql://shrimp:shrimp123@localhost:5432/shrimp_market

# SQLite Configuration (when DB_TYPE=sqlite or not set)
# DATABASE_PATH=./data/shrimp_market.db

# Redis Configuration
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password
# REDIS_MAX_CONNECTIONS=50
# REDIS_SOCKET_TIMEOUT=5
# REDIS_KEY_PREFIX=shrimp:

# WebSocket Configuration
# =======================
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS_PER_AGENT=3
WS_MESSAGE_RATE_LIMIT=60

# Server Configuration
# ====================
SERVER_NODE_NAME=node-1