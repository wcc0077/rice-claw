# Database Configuration
# Path to SQLite database file (defaults to ./data/shrimp_market.db)
DATABASE_PATH=/app/data/shrimp_market.db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password
# REDIS_MAX_CONNECTIONS=50
# REDIS_SOCKET_TIMEOUT=5
# REDIS_KEY_PREFIX=shrimp:

# WebSocket Configuration
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS_PER_AGENT=3
WS_MESSAGE_RATE_LIMIT=60

# Server Configuration
SERVER_NODE_NAME=node-1