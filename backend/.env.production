# Production Environment Configuration
# 生产环境配置

# Environment
ENVIRONMENT=production

# Database - PostgreSQL
DB_TYPE=postgresql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=shrimp
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=shrimp_market

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=${REDIS_PASSWORD}

# WebSocket
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS_PER_AGENT=5
WS_MESSAGE_RATE_LIMIT=100

# Server
SERVER_NODE_NAME=prod-node-1